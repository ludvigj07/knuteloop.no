# Production environment for the Knuteloop Node service.
# Copy to /etc/knuteloop.env on the server and secure it:
#   sudo cp deploy/knuteloop.env.example /etc/knuteloop.env
#   sudo chown root:knuteloop /etc/knuteloop.env
#   sudo chmod 640 /etc/knuteloop.env
#
# systemd reads this on every start. After edits:
#   sudo systemctl restart knuteloop

PORT=3001

# Lock CORS to the live origin. Vite dev proxies same-origin so this does
# not affect local development. Multiple origins are not supported today —
# add logic in index.mjs if that becomes needed.
ALLOWED_ORIGIN=https://knuteloop.no

# Node runtime flags
NODE_ENV=production

# --- Coming later ---------------------------------------------------------
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# INVITE_FROM_EMAIL=noreply@knuteloop.no
