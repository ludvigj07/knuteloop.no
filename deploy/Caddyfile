# Caddy config for knuteloop.no
#
# Install path (suggested): /etc/caddy/Caddyfile
# Reload after edits:       sudo systemctl reload caddy
#
# Assumes:
#   - Built frontend assets live at /opt/knuteloop/current/dist
#   - Node API server listens on 127.0.0.1:3001
#   - DNS for knuteloop.no (A/AAAA) points at this Hetzner box

knuteloop.no, www.knuteloop.no {
	# Redirect www -> apex
	@www host www.knuteloop.no
	redir @www https://knuteloop.no{uri} permanent

	# Reverse-proxy the API to Node. Node already sets its own cache/CORS headers.
	# Caddy sets Host, X-Forwarded-For and X-Forwarded-Proto automatically.
	handle /api/* {
		reverse_proxy 127.0.0.1:3001
	}

	# Uploaded images/videos are served by Node (cache-friendly, range-aware).
	handle /uploads/* {
		reverse_proxy 127.0.0.1:3001
	}

	# Static frontend build output.
	handle {
		root * /opt/knuteloop/current/dist

		# Long-cache for hashed Vite assets (file names include a content hash).
		@hashed path /assets/*
		header @hashed Cache-Control "public, max-age=31536000, immutable"

		# Short cache for PWA manifest + icons (filenames are stable, contents may change).
		@pwa path /manifest.webmanifest /icon-*.png /favicon.*
		header @pwa Cache-Control "public, max-age=3600"

		# No cache for index.html — it references the hashed assets and must be fresh.
		@html path /index.html /
		header @html Cache-Control "no-cache"

		# SPA fallback so deep links like /knuter/123 serve index.html.
		try_files {path} /index.html
		file_server
	}

	# Compress responses Caddy generates itself (file_server). Caddy will NOT
	# re-encode proxy responses that already carry Content-Encoding.
	encode zstd gzip

	# Access logs go to journald via stdout — view with:
	#   journalctl -u caddy -f
}
